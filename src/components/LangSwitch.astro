---
// Obtenemos la URL actual para saber en qué idioma estamos
const { pathname } = Astro.url;

// Lógica simple para determinar el estado activo
const isEnglish = pathname.startsWith('/en');
---

<div class="lang-switch">
  <a href="/es" class={!isEnglish ? "active" : ""}>ES</a>
  <span class="separator">|</span>
  <a href="/en" class={isEnglish ? "active" : ""}>EN</a>
</div>

<style>
  .lang-switch {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    font-size: 0.75rem;
    font-weight: 600;
  }

  a {
    text-decoration: none;
    color: #666;
    transition: all 0.2s ease;
    padding: 4px 8px;
    border-radius: 4px;
  }

  a:hover {
    background: #eee;
    color: #000;
  }

  a.active {
    color: #fff;
    background: #1868db; /* El azul de Confluence que te gusta */
  }

  .separator {
    color: #ccc;
    user-select: none;
  }

  /* Adaptación para modo oscuro (si tu ThemeSwitch usa una clase en el body o html) */
  :global(.dark) a {
    color: #aaa;
  }
  :global(.dark) a:hover {
    background: #333;
    color: #fff;
  }
</style>